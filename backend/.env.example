NODE_ENV=development
PORT=3000

# PostgreSQL (Railway provides this automatically)
DATABASE_URL=postgresql://user:password@localhost:5432/realitycheck

# JWT
JWT_SECRET=your-long-random-secret-here-min-32-chars
JWT_EXPIRES_IN=7d

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-...

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PREMIUM_PRICE_ID=price_...

# Nodemailer (SMTP)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=SG...
EMAIL_FROM=digest@realitycheck.app

# Google OAuth (for server-side token verification)
GOOGLE_CLIENT_ID=...apps.googleusercontent.com

# App
APP_URL=https://yourapp.railway.app
ADMIN_URL=https://admin.vercel.app
